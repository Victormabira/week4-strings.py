    my_list = SinglyLinkedList()
    my_list.head = Node(10)
    my_list.head.next = Node(20)
    my_list.head.next.next = Node(30)
    my_list.prepend(5)
    return my_list
my_list = create_list() # Output: 5 10 20 30 None
my_list.display()  # Output: 5 10 20 30 None

